{
  "name": "astoria-cpw",
  "version": "1.0.0",
  "description": "Astoria Central Park West — Concierge Portal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.astoriacpw.concierge",
    "productName": "Astoria CPW Concierge",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Astoria CPW Concierge"
    },
    "files": ["main.js","src/**/*"],
    "directories": { "buildResources": "." }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
